Q1)
SELECT e.f_name, e.l_name, d.dept_name, e.salary
FROM employee e
JOIN department d ON e.dept_id = d.dept_id
WHERE e.salary > (
    SELECT AVG(salary)
    FROM employee e2
    JOIN department d2 ON e2.dept_id = d2.dept_id
    WHERE d2.dept_name = 'Finance'
);

Q2)
SELECT e.f_name, e.l_name, d.dept_name, COUNT(w.proj_id) AS num_projects
FROM employee e
JOIN works_on w   ON e.emp_id  = w.emp_id
JOIN project p    ON w.proj_id = p.proj_id
JOIN department d ON p.dept_id = d.dept_id
WHERE d.dept_name = 'R&D'
GROUP BY e.emp_id, e.f_name, e.l_name, d.dept_name
HAVING COUNT(w.proj_id) > 2;

Q3)
SELECT p.proj_id, p.project_title, d.dept_name, p.completion_date
FROM project p
JOIN department d ON p.dept_id = d.dept_id
WHERE p.completion_date IS NULL;

Q4)
SELECT supervisor_id, COUNT(emp_id)
FROM employee
WHERE supervisor_id IS NOT NULL   
GROUP BY supervisor_id
HAVING COUNT(emp_id) > 3;

Q5)
SELECT e.emp_id, e.f_name, SUM(p.project_amount) AS total_amount, d.dependent_name
FROM employee e
JOIN works_on w  ON e.emp_id  = w.emp_id
JOIN project p   ON w.proj_id = p.proj_id
JOIN dependent d ON e.emp_id  = d.emp_id
GROUP BY e.emp_id, e.f_name, d.dependent_name
HAVING SUM(p.project_amount) >= 1000000;

Q6)
SELECT DISTINCT e.emp_id AS Employee_id,
       e.dept_id AS Department_id,
       p.project_id,
       p.city
FROM Employee e
JOIN Works_on w ON e.emp_id = w.emp_id
JOIN Project p ON w.project_id = p.project_id
WHERE p.project_id IN
(
    SELECT project_id
    FROM Project
    GROUP BY project_id
    HAVING COUNT(DISTINCT city) > 1
);

