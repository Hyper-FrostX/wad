-- 1. Create database
CREATE DATABASE hrm;
USE hrm;

-- 2. Department (first, no dependencies)
CREATE TABLE department (
    dept_id   INT PRIMARY KEY,
    dept_name VARCHAR(50) NOT NULL
);

-- 3. Employee (depends on department)
CREATE TABLE employee (
    emp_id        INT PRIMARY KEY,
    f_name        VARCHAR(50) NOT NULL,
    l_name        VARCHAR(50) NOT NULL,
    salary        DECIMAL(10,2),
    dept_id       INT,
    supervisor_id INT,
    FOREIGN KEY (dept_id)       REFERENCES department(dept_id),
    FOREIGN KEY (supervisor_id) REFERENCES employee(emp_id)
);

-- 4. Project (depends on department)
CREATE TABLE project (
    proj_id          INT PRIMARY KEY,
    project_title    VARCHAR(100) NOT NULL,
    completion_date  DATE,
    project_amount   DECIMAL(10,2),
    city             VARCHAR(50),
    dept_id          INT,
    FOREIGN KEY (dept_id) REFERENCES department(dept_id)
);

-- 5. Works_On (depends on employee + project)
CREATE TABLE works_on (
    emp_id  INT,
    proj_id INT,
    PRIMARY KEY (emp_id, proj_id),
    FOREIGN KEY (emp_id)  REFERENCES employee(emp_id),
    FOREIGN KEY (proj_id) REFERENCES project(proj_id)
);

-- 6. Dependent (depends on employee)
CREATE TABLE dependent (
    emp_id         INT,
    dependent_name VARCHAR(50),
    relationship   VARCHAR(50),
    PRIMARY KEY (emp_id, dependent_name),
    FOREIGN KEY (emp_id) REFERENCES employee(emp_id)
);

