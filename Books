<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Books Catalogue</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<header class="bg-dark text-white p-3">
    <h1 class="text-center">Books Catalogue</h1>
</header>

<nav class="navbar navbar-expand-lg navbar-light bg-info">
    <div class="container-fluid">
        <a class="navbar-brand" href="index.html">Books📚</a>
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" href="index.html">Home</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" href="books.html">Books Catalogue</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="profile.html">User Profile</a>
            </li>
        </ul>
    </div>
</nav>

<section class="container mt-4">
    <input type="text" class="form-control mb-4" placeholder="Search book by name">

    <div class="row">

        <article class="col-md-4">
            <div class="card">
                <img src="https://via.placeholder.com/200x250" class="card-img-top" alt="CSS Book">
                <div class="card-body">
                    <h5 class="card-title">Learn CSS</h5>
                    <p class="card-text">Price: ₹300</p>
                    <a href="#" class="btn btn-success">Buy</a>
                </div>
            </div>
        </article>

        <article class="col-md-4">
            <div class="card">
                <img src="https://via.placeholder.com/200x250" class="card-img-top" alt="HTML Book">
                <div class="card-body">
                    <h5 class="card-title">HTML5 Guide</h5>
                    <p class="card-text">Price: ₹350</p>
                    <a href="#" class="btn btn-success">Buy</a>
                </div>
            </div>
        </article>

        <article class="col-md-4">
            <div class="card">
                <img src="https://via.placeholder.com/200x250" class="card-img-top" alt="Bootstrap Book">
                <div class="card-body">
                    <h5 class="card-title">Bootstrap Basics</h5>
                    <p class="card-text">Price: ₹400</p>
                    <a href="#" class="btn btn-success">Buy</a>
                </div>
            </div>
        </article>

    </div>
</section>

<footer class="bg-dark text-white text-center p-3 mt-4">
    <p>&copy; 2025 Online Book Store</p>
</footer>

</body>
</html>

