<!DOCTYPE html>
<html>
<head>
	<title>Inventory mgmt</title>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>

<body>

<div class="container">
	<h4 id="title" class="text-center mb-3">Inventory Management</h4>
	
	<input type="text" id="item" class="form-control mb-2" placeholder="Enter Item">
	<input type="number" id="qty" class="form-control mb-2" placeholder="Quantity">
	
	<button onclick="addItem()" class="btn btn-primary mb-3">Add</button>
	<button onclick="clearAll()" class="btn btn-danger mb-3">clear all</button>

	<table class="table table-bordered">
		<thead class="table-dark">
			<tr>
				<th>Item</th>
				<th>qty</th>
				<th>Action</th>
			</tr>
		</thead>
		<tbody id="list"></tbody>
	</table>
</div>

<script>
	console.log("Java script loaded");
	
	//change title
	document.getElementById("title").innerHTML += "(DOM)";

	function addItem()
	{
		console.log("Add button clicked");
		
		let name=document.getElementById("item").value;
		let qty=document.getElementById("qty").value;
	
		if(name === "" || qty === "")
		{
			alert("Enter Item and quentity");
			return;
		}
	
		//createv table row using DOM
		let row=document.createElement("tr");
		
		row.innerHTML =
		"<td>" + name + "</td>" +
		"<td>" + qty + "</td>" +
		"<td><button class='btn btn-danger'>Delete</button></td>";
		
		//delete button using dom
		
		row.querySelector("button").addEventListener("click",function()
		{
			row.remove();
			console.log("Item deleted:",name);
		});
		
		//add row to table
		document.getElementById("list").appendChild(row);
		console.log("Item added:",name,qty);
		
		//clear inputs
		document.getElementById("item").value = "";
		document.getElementById("qty").value = "";
	}
	function clearAll()
	{
		document.getElementById("list").innerHTML = "";
		console.log("All items cleared");
	
	}
</script>
</body>
</html>
